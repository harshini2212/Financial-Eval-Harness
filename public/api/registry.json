[{"id": "bs.balance", "kind": "equality", "description": "Assets = Liabilities + Total equity + Mezzanine equity", "severity": "hard", "formula": "assets.total = liabilities.total + equity.total + equity.temporary", "tolerance": {"abs": 1.0, "rel": 0.005, "rel_ground_truth": 0.0}}, {"id": "bs.lse_crosscheck", "kind": "equality", "description": "Total liabilities & equity = Total assets", "severity": "hard", "formula": "liabilities_and_equity.total = assets.total", "tolerance": {"abs": 1.0, "rel": 0.005, "rel_ground_truth": 0.0}}, {"id": "bs.lse_decomp", "kind": "equality", "description": "Total liabilities & equity = Liabilities + Equity + Mezzanine", "severity": "hard", "formula": "liabilities_and_equity.total = liabilities.total + equity.total + equity.temporary", "tolerance": {"abs": 1.0, "rel": 0.005, "rel_ground_truth": 0.0}}, {"id": "bs.assets_split", "kind": "equality", "description": "Assets = Current + Non-current assets", "severity": "hard", "formula": "assets.total = assets.current + assets.noncurrent", "tolerance": {"abs": 1.0, "rel": 0.005, "rel_ground_truth": 0.0}}, {"id": "bs.liabilities_split", "kind": "equality", "description": "Liabilities = Current + Non-current liabilities", "severity": "hard", "formula": "liabilities.total = liabilities.current + liabilities.noncurrent", "tolerance": {"abs": 1.0, "rel": 0.005, "rel_ground_truth": 0.0}}, {"id": "bs.equity_attribution", "kind": "equality", "description": "Total equity = Parent equity + NCI", "severity": "hard", "formula": "equity.total = equity.parent + equity.nci", "tolerance": {"abs": 1.0, "rel": 0.005, "rel_ground_truth": 0.0}}, {"id": "is.gross_profit", "kind": "equality", "description": "Gross profit = Revenue - Cost of revenue", "severity": "hard", "formula": "gross_profit.total = revenue.total - cogs.total", "tolerance": {"abs": 1.0, "rel": 0.005, "rel_ground_truth": 0.0}}, {"id": "is.operating_income", "kind": "equality", "description": "Operating income = Gross profit - Operating expenses", "severity": "hard", "formula": "operating_income.total = gross_profit.total - opex.total", "tolerance": {"abs": 1.0, "rel": 0.005, "rel_ground_truth": 0.0}}, {"id": "is.pretax_to_net", "kind": "equality", "description": "Consolidated net income = Pretax - Tax + Equity-method + Discontinued ops", "severity": "soft", "formula": "net_income.consolidated = pretax_income.total - income_tax.total + income.equity_method + income.discontinued", "tolerance": {"abs": 1.0, "rel": 0.005, "rel_ground_truth": 0.0}}, {"id": "is.net_income_attribution", "kind": "equality", "description": "Consolidated net income = Parent + NCI", "severity": "hard", "formula": "net_income.consolidated = net_income.parent + net_income.nci", "tolerance": {"abs": 1.0, "rel": 0.005, "rel_ground_truth": 0.0}}, {"id": "rev.segments_sum", "kind": "sum", "description": "Sum of segment revenue = Total revenue", "severity": "hard", "formula": "revenue.total = sum(revenue.segment[segment])", "tolerance": {"abs": 1.0, "rel": 0.005, "rel_ground_truth": 0.0}}, {"id": "opinc.segments_sum", "kind": "sum", "description": "Sum of segment operating income = Operating income", "severity": "hard", "formula": "operating_income.total = sum(operating_income.segment[segment])", "tolerance": {"abs": 1.0, "rel": 0.005, "rel_ground_truth": 0.0}}, {"id": "margin.gross", "kind": "ratio_def", "description": "Gross margin = Gross profit / Revenue", "severity": "hard", "formula": "gross_margin.ratio = gross_profit.total / revenue.total", "tolerance": {"abs": 0.0005, "rel": 0.01, "rel_ground_truth": 0.0005}}, {"id": "margin.operating", "kind": "ratio_def", "description": "Operating margin = Operating income / Revenue", "severity": "hard", "formula": "operating_margin.ratio = operating_income.total / revenue.total", "tolerance": {"abs": 0.0005, "rel": 0.01, "rel_ground_truth": 0.0005}}, {"id": "margin.net", "kind": "ratio_def", "description": "Net margin = Net income (parent) / Revenue", "severity": "hard", "formula": "net_margin.ratio = net_income.parent / revenue.total", "tolerance": {"abs": 0.0005, "rel": 0.01, "rel_ground_truth": 0.0005}}, {"id": "tax.effective_rate", "kind": "ratio_def", "description": "Effective tax rate = Income tax / Pretax income", "severity": "hard", "formula": "effective_tax_rate.ratio = income_tax.total / pretax_income.total", "tolerance": {"abs": 0.0005, "rel": 0.01, "rel_ground_truth": 0.0005}}]